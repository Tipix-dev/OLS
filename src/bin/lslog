#!/usr/bin/env bash
# OLS command: lslog


set -euo pipefail
IFS=$'\n\t'

# shellcheck source=src/lib/env.sh
source "$HOME/.local/share/OLS/lib/env.sh"

# ===== Help =====
show_help() {
	cat <<'EOF'
lslog - View OLS activity logs

usage:
    lslog              Display all log entries
    lslog --help       Show this help message
    lslog --debug      Display all log for [EE] and [PANIC]

description:
    Prints the contents of the OLS log file (~/.local/share/OLS/logs/events.log).
    Each log entry includes a timestamp, component name, and message.
    Pipe the output to filter, sort, or search log entries.

examples:
    lslog                    show all logs
    lslog | grep EE          show only errors
    lslog | grep gx          show only gx command logs
    lslog | tail -20         show the last 20 log entries
    lslog | sort | uniq      show unique log entries
EOF
}


if [[ "${1-}" == "--help" ]]; then
    show_help
    exit 0
fi

# ===== Args =====
case "${1-}" in
    -G|--global)
        if [[ -f /var/log/messages ]]; then
            tail -n 50 "/var/log/messages"
        elif [[ -f /var/log/syslog ]]; then
            tail -n 50 "/var/log/syslog"
        elif [[ -d /var/log/journal/ ]]; then
            journalctl | tail -n 50
        fi
        ;;
    --debug)
        [[ ! -f "$DEBUG_LOG_FILE" ]] && panic "file debug.log not found"
        cat "$DEBUG_LOG_FILE"
        ;;
    *)
        [[ ! -f "$LOG_FILE" ]] && panic "file events.log not found"
        cat "$LOG_FILE"
        ;;
esac
